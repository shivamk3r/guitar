{
  "name": "guitar-coach",
  "private": true,
  "version": "0.1.0",
  "description": "An end-to-end guitar learning platform with real-time feedback and consented practice analysis.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shivamk3r/guitar.git"
  },
  "bugs": {
    "url": "https://github.com/shivamk3r/guitar/issues"
  },
  "scripts": {
    "dev": "docker compose up --build",
    "dev:frontend": "pnpm --filter @guitar/frontend dev",
    "build": "pnpm --filter @guitar/frontend build",
    "preview": "pnpm --filter @guitar/frontend preview",
    "test": "pnpm test:frontend && pnpm test:backend",
    "test:frontend": "pnpm --filter @guitar/frontend test",
    "test:backend": "cd apps/backend && python3 -m pytest",
    "test:e2e": "pnpm --filter @guitar/frontend test:e2e",
    "eval:chords": "pnpm eval:chords:frontend",
    "eval:chords:frontend": "pnpm --filter @guitar/frontend eval:chords",
    "eval:chords:python": "cd apps/backend && python3 -m app.evals.chord_detection.cli",
    "eval:chords:compare": "pnpm --filter @guitar/frontend eval:chords:compare",
    "eval:chords:prepare": "pnpm --filter @guitar/frontend eval:chords:prepare",
    "lint": "pnpm lint:frontend && pnpm lint:backend",
    "lint:frontend": "pnpm --filter @guitar/frontend lint",
    "lint:backend": "cd apps/backend && python3 -m compileall app tests",
    "format": "pnpm --filter @guitar/frontend format",
    "typecheck": "pnpm --filter @guitar/frontend typecheck",
    "compose:config": "docker compose config"
  },
  "packageManager": "pnpm@10.33.0"
}
